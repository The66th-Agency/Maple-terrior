# Shopify checkout passthrough — mapleterroir.com is Cloudflare Pages now,
# so /cart/* and /checkout/* must redirect to Shopify or every checkout 404s.
/cart/*       https://maple-terroir.myshopify.com/cart/:splat       302
/checkout/*   https://maple-terroir.myshopify.com/checkout/:splat   302
/checkouts/*  https://maple-terroir.myshopify.com/checkouts/:splat  302
/account      https://maple-terroir.myshopify.com/account           302
/account/*    https://maple-terroir.myshopify.com/account/:splat    302

# Renamed pages — preserve SEO equity from old URLs
/wholesale.html  /maple-syrup-wholesale  301
/wholesale       /maple-syrup-wholesale  301

/collections/stroopwafels.html  /collections/maple-stroopwafels  301
/collections/stroopwafels       /collections/maple-stroopwafels  301

/collections/maple-syrup.html  /collections/premium-maple-syrup  301
/collections/maple-syrup       /collections/premium-maple-syrup  301

/collections/gift-sets.html  /collections/maple-syrup-gift-set  301
/collections/gift-sets       /collections/maple-syrup-gift-set  301

# Legacy Shopify blog URLs → Cloudflare Pages blog template.
# All articles still live in Shopify (headless); blog/post.html fetches them by handle
# via the Storefront API. Before these rules, ~700k monthly GSC impressions were
# landing on 404s because the Shopify→CF Pages cutover dropped the /blogs/* path.
# 301 to preserve link equity and keep the rankings alive.
/blogs/blogs-maple-terroir       /blog/                                              301
/blogs/blogs-maple-terroir/*     /blog/post?handle=:splat&blog=blogs-maple-terroir   301
